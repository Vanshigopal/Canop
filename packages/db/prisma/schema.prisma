generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ════════════════════════════════════════════════════════
// ENUMS
// ════════════════════════════════════════════════════════

enum UserRole {
  ADMIN
  TEACHER
  STAFF
  PARENT
  STUDENT
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
  TRIAL
}

enum TenantTier {
  BASIC
  PROFESSIONAL
  ENTERPRISE
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum GuardianRelation {
  FATHER
  MOTHER
  GUARDIAN
  OTHER
}

enum JoinRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AttendanceType {
  LECTURE
  EXAM
  RETEST
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
}

enum AttendanceMethod {
  QR_SCAN
  MANUAL
  BULK
}

enum InstallmentFrequency {
  MONTHLY
  QUARTERLY
  HALF_YEARLY
  ANNUALLY
  CUSTOM
}

enum FeeStatus {
  PENDING
  PARTIALLY_PAID
  PAID
  OVERDUE
  WAIVED
}

enum DiscountType {
  PERCENTAGE
  FLAT
  SCHOLARSHIP
  SIBLING
  MERIT
  CUSTOM
}

enum InstallmentStatus {
  UPCOMING
  DUE
  OVERDUE
  PAID
  PARTIALLY_PAID
}

enum PaymentMethod {
  CASH
  UPI
  CARD
  NETBANKING
  CHEQUE
  RAZORPAY_ONLINE
  BANK_TRANSFER
  OTHER
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum ExamType {
  THEORY
  MCQ
  THEORY_MCQ
  OBJECTIVE
  NUMERICAL
}

enum ExamStatus {
  DRAFT
  SCHEDULED
  IN_PROGRESS
  MARKS_ENTRY
  UNDER_REVIEW
  PUBLISHED
  CANCELLED
}

enum CutOffType {
  MARKS
  PERCENTAGE
}

enum RetestStatus {
  PENDING_SCHEDULE
  SCHEDULED
  COMPLETED
  NO_SHOW
  CANCELLED
}

enum LLMMode {
  DISABLED
  PLATFORM_KEY
  BRING_YOUR_OWN_KEY
}

enum LLMProviderName {
  ANTHROPIC_CLAUDE
  OPENAI_GPT
  LOCAL_LLAMA
}

enum LLMRequestStatus {
  SUCCESS
  STUBBED
  FAILED_DISABLED
  FAILED_CAP_REACHED
  FAILED_INVALID_KEY
  FAILED_RATE_LIMIT
  FAILED_PROVIDER_ERROR
  FAILED_TIMEOUT
  FAILED_REDACTION
}

enum ContentAccessType {
  BATCH
  SUBJECT
  INSTITUTE
}

enum MaterialType {
  PDF
  DOCX
  PPT
  IMAGE
  OTHER
}

enum MaterialAction {
  VIEWED
  DOWNLOADED
}

enum VideoStatus {
  UPLOADING
  TRANSCODING
  READY
  FAILED
}

enum AssignmentStatus {
  DRAFT
  PUBLISHED
  CLOSED
}

enum SubmissionStatus {
  NOT_OPENED
  OPENED
  IN_PROGRESS
  SUBMITTED
  LATE_SUBMITTED
  GRADED
  MISSED
}

// ════════════════════════════════════════════════════════
// CORE PLATFORM — not tenant-scoped (global tables)
// ════════════════════════════════════════════════════════

model Tenant {
  id           String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug         String       @unique @db.VarChar(30)
  name         String       @db.VarChar(200)
  status       TenantStatus @default(TRIAL)
  tier         TenantTier   @default(BASIC)
  logoUrl      String?      @map("logo_url")
  primaryColor String?      @map("primary_color") @db.VarChar(7)
  tagline      String?      @db.VarChar(300)
  timezone     String       @default("Asia/Kolkata") @db.VarChar(50)
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")
  deletedAt    DateTime?    @map("deleted_at")

  users                 User[]
  auditLogs             AuditLog[]
  subjects              Subject[]
  classes               ClassStandard[]
  batches               Batch[]
  students              Student[]
  inviteLinks           InviteLink[]
  joinRequests          JoinRequest[]
  attendanceSessions    AttendanceSession[]
  feeCategories         FeeCategory[]
  feePlans              FeePlan[]
  studentFees           StudentFee[]
  notificationTemplates NotificationTemplate[]
  broadcastCampaigns    BroadcastCampaign[]
  exams                 Exam[]
  recentItems           RecentItem[]
  engagementSnapshots   EngagementSnapshot[]
  omrScanResults        OmrScanResult[]
  llmConfig             LLMConfig?
  llmRequestLogs        LLMRequestLog[]
  llmSpendCap           LLMSpendCap?
  studyMaterials        StudyMaterial[]
  materialBatchAccess   MaterialBatchAccess[]
  materialAccessLogs    MaterialAccessLog[]
  videoLectures         VideoLecture[]
  videoBatchAccess      VideoBatchAccess[]
  videoWatchSessions    VideoWatchSession[]
  assignments           Assignment[]
  assignmentAttachments AssignmentAttachment[]
  assignmentSubmissions AssignmentSubmission[]
  submissionFiles       SubmissionFile[]
  analyticsSnapshots    AnalyticsSnapshot[]

  @@map("tenants")
}

// ════════════════════════════════════════════════════════
// TENANT-SCOPED TABLES — all have tenant_id + RLS
// ════════════════════════════════════════════════════════

model User {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String    @map("tenant_id") @db.Uuid
  email        String    @db.VarChar(255)
  passwordHash String?   @map("password_hash")
  name         String    @db.VarChar(200)
  role         UserRole  @default(ADMIN)
  phone        String?   @db.VarChar(15)
  avatarUrl    String?   @map("avatar_url")
  isActive     Boolean   @default(true) @map("is_active")
  lastLoginAt  DateTime? @map("last_login_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  tenant                   Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sessions                 Session[]
  auditLogs                AuditLog[]
  permissions              Permission?
  student                  Student?
  guardianOf               Guardian[]
  teacherSubjects          TeacherSubject[] @relation("TeacherSubjects")
  batchSubjects            BatchSubject[]   @relation("TeacherBatchSubjects")
  createdInvites           InviteLink[]     @relation("InviteCreator")
  reviewedJoinRequests     JoinRequest[]    @relation("JoinRequestReviewer")
  markedAttendanceSessions AttendanceSession[] @relation("AttendanceMarker")
  markedAttendanceRecords  AttendanceRecord[]  @relation("AttendanceRecordMarker")
  collectedPayments        Payment[]           @relation("PaymentCollector")
  broadcastCampaigns       BroadcastCampaign[]     @relation("BroadcastCreator")
  notificationPreferences  NotificationPreference[]
  consentRecords           ConsentRecord[]
  createdExams             Exam[]                  @relation("ExamCreator")
  publishedExams           Exam[]                  @relation("ExamPublisher")
  enteredMarks             MarkEntry[]             @relation("MarkEnterer")
  confirmedRetests         Retest[]                @relation("RetestConfirmer")
  enteredRetestMarks       Retest[]                @relation("RetestMarksEnterer")
  recentItems              RecentItem[]
  scannedOmrResults        OmrScanResult[]         @relation("OmrScanner")
  llmRequestLogs           LLMRequestLog[]
  uploadedMaterials        StudyMaterial[]         @relation("MaterialUploader")
  materialAccessLogs       MaterialAccessLog[]
  uploadedVideos           VideoLecture[]          @relation("VideoUploader")
  videoWatchSessions       VideoWatchSession[]
  createdAssignments       Assignment[]            @relation("AssignmentCreator")
  gradedSubmissions        AssignmentSubmission[]  @relation("SubmissionGrader")
  dashboardLayout          DashboardLayout?
  exportJobs               ExportJob[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([tenantId, role])
  @@index([tenantId, phone])
  @@map("users")
}

model Session {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  refreshToken String   @unique @map("refresh_token")
  userAgent    String?  @map("user_agent") @db.VarChar(500)
  ipAddress    String?  @map("ip_address") @db.VarChar(45)
  expiresAt    DateTime @map("expires_at")
  createdAt    DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([userId])
  @@index([refreshToken])
  @@map("sessions")
}

model AuditLog {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  userId    String?  @map("user_id") @db.Uuid
  action    String   @db.VarChar(100)
  entity    String   @db.VarChar(100)
  entityId  String?  @map("entity_id") @db.Uuid
  before    Json?
  after     Json?
  ipAddress String?  @map("ip_address") @db.VarChar(45)
  createdAt DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([tenantId, entity])
  @@index([tenantId, userId])
  @@index([createdAt])
  @@map("audit_logs")
}

model Permission {
  id                   String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId             String   @map("tenant_id") @db.Uuid
  userId               String   @unique @map("user_id") @db.Uuid
  canManageFees        Boolean  @default(false) @map("can_manage_fees")
  canApproveAdmissions Boolean  @default(false) @map("can_approve_admissions")
  canManageExams       Boolean  @default(false) @map("can_manage_exams")
  canManageAttendance  Boolean  @default(false) @map("can_manage_attendance")
  canManageTimetable   Boolean  @default(false) @map("can_manage_timetable")
  canSendBroadcasts    Boolean  @default(false) @map("can_send_broadcasts")
  canViewAnalytics     Boolean  @default(false) @map("can_view_analytics")
  canManageContent     Boolean  @default(false) @map("can_manage_content")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@index([tenantId])
  @@map("permissions")
}

// ════════════════════════════════════════════════════════
// ACADEMIC STRUCTURE
// ════════════════════════════════════════════════════════

model Subject {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String    @map("tenant_id") @db.Uuid
  name        String    @db.VarChar(100)
  code        String?   @db.VarChar(20)
  description String?   @db.VarChar(500)
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  tenant             Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  batchSubjects      BatchSubject[]
  teacherSubjects    TeacherSubject[]
  attendanceSessions AttendanceSession[]
  exams              Exam[]
  studyMaterials     StudyMaterial[]
  videoLectures      VideoLecture[]
  assignments        Assignment[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("subjects")
}

model ClassStandard {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId   String    @map("tenant_id") @db.Uuid
  name       String    @db.VarChar(50)
  orderIndex Int       @default(0) @map("order_index")
  isActive   Boolean   @default(true) @map("is_active")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  deletedAt  DateTime? @map("deleted_at")

  tenant      Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  batches     Batch[]
  students    Student[]
  inviteLinks InviteLink[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("class_standards")
}

model Batch {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String    @map("tenant_id") @db.Uuid
  classId      String    @map("class_id") @db.Uuid
  name         String    @db.VarChar(100)
  capacity     Int       @default(60)
  academicYear String    @map("academic_year") @db.VarChar(9)
  startDate    DateTime? @map("start_date")
  endDate      DateTime? @map("end_date")
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  tenant             Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  class              ClassStandard  @relation(fields: [classId], references: [id])
  batchSubjects      BatchSubject[]
  students           Student[]
  inviteLinks        InviteLink[]
  attendanceSessions AttendanceSession[]
  studentBatches     StudentBatch[]
  feePlans           FeePlan[]
  exams              Exam[]
  materialAccess     MaterialBatchAccess[]
  videoAccess        VideoBatchAccess[]
  assignments        Assignment[]
  assignmentAccess   AssignmentBatchAccess[]

  @@unique([tenantId, name, academicYear])
  @@index([tenantId])
  @@index([tenantId, classId])
  @@map("batches")
}

model BatchSubject {
  id        String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String  @map("tenant_id") @db.Uuid
  batchId   String  @map("batch_id") @db.Uuid
  subjectId String  @map("subject_id") @db.Uuid
  teacherId String? @map("teacher_id") @db.Uuid

  batch   Batch   @relation(fields: [batchId], references: [id], onDelete: Cascade)
  subject Subject @relation(fields: [subjectId], references: [id])
  teacher User?   @relation("TeacherBatchSubjects", fields: [teacherId], references: [id])

  @@unique([batchId, subjectId])
  @@index([tenantId])
  @@map("batch_subjects")
}

// ════════════════════════════════════════════════════════
// TEACHER PROFILE (extends User with role TEACHER)
// ════════════════════════════════════════════════════════

model TeacherSubject {
  id        String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String @map("tenant_id") @db.Uuid
  teacherId String @map("teacher_id") @db.Uuid
  subjectId String @map("subject_id") @db.Uuid

  teacher User    @relation("TeacherSubjects", fields: [teacherId], references: [id], onDelete: Cascade)
  subject Subject @relation(fields: [subjectId], references: [id])

  @@unique([teacherId, subjectId])
  @@index([tenantId])
  @@map("teacher_subjects")
}

// ════════════════════════════════════════════════════════
// STUDENT & GUARDIAN (created via enrollment flow)
// ════════════════════════════════════════════════════════

model Student {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String    @map("tenant_id") @db.Uuid
  userId         String    @unique @map("user_id") @db.Uuid
  batchId        String?   @map("batch_id") @db.Uuid
  classId        String?   @map("class_id") @db.Uuid
  rollNumber     String?   @map("roll_number") @db.VarChar(30)
  dateOfBirth    DateTime? @map("date_of_birth") @db.Date
  gender         Gender?
  address        String?   @db.VarChar(500)
  city           String?   @db.VarChar(100)
  state          String?   @db.VarChar(100)
  pincode        String?   @db.VarChar(10)
  previousSchool String?   @map("previous_school") @db.VarChar(200)
  bloodGroup     String?   @map("blood_group") @db.VarChar(5)
  photoUrl       String?   @map("photo_url")
  enrolledAt     DateTime  @default(now()) @map("enrolled_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  tenant                Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user                  User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  batch                 Batch?         @relation(fields: [batchId], references: [id])
  class                 ClassStandard? @relation(fields: [classId], references: [id])
  guardians             Guardian[]
  attendanceRecords     AttendanceRecord[]
  batches               StudentBatch[]
  fees                  StudentFee[]
  markEntries           MarkEntry[]
  retests               Retest[]
  engagementSnapshots   EngagementSnapshot[]
  omrScanResults        OmrScanResult[]
  materialAccessLogs    MaterialAccessLog[]
  videoWatchSessions    VideoWatchSession[]
  assignmentSubmissions AssignmentSubmission[]

  @@index([tenantId])
  @@index([tenantId, batchId])
  @@map("students")
}

model Guardian {
  id          String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String           @map("tenant_id") @db.Uuid
  studentId   String           @map("student_id") @db.Uuid
  userId      String?          @map("user_id") @db.Uuid
  name        String           @db.VarChar(200)
  relation    GuardianRelation
  phone       String           @db.VarChar(15)
  email       String?          @db.VarChar(255)
  occupation  String?          @db.VarChar(100)
  isEmergency Boolean          @default(false) @map("is_emergency")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id])

  @@index([tenantId])
  @@index([studentId])
  @@map("guardians")
}

// ════════════════════════════════════════════════════════
// ENROLLMENT FLOW (invite → form → approval)
// ════════════════════════════════════════════════════════

model InviteLink {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String    @map("tenant_id") @db.Uuid
  code        String    @unique @db.VarChar(12)
  batchId     String?   @map("batch_id") @db.Uuid
  classId     String?   @map("class_id") @db.Uuid
  createdById String    @map("created_by_id") @db.Uuid
  maxUses     Int       @default(0) @map("max_uses")
  usedCount   Int       @default(0) @map("used_count")
  expiresAt   DateTime? @map("expires_at")
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")

  tenant       Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  batch        Batch?         @relation(fields: [batchId], references: [id])
  class        ClassStandard? @relation(fields: [classId], references: [id])
  createdBy    User           @relation("InviteCreator", fields: [createdById], references: [id])
  joinRequests JoinRequest[]

  @@index([tenantId])
  @@index([code])
  @@map("invite_links")
}

model JoinRequest {
  id             String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String            @map("tenant_id") @db.Uuid
  inviteLinkId   String?           @map("invite_link_id") @db.Uuid
  status         JoinRequestStatus @default(PENDING)
  studentName    String            @map("student_name") @db.VarChar(200)
  studentPhone   String            @map("student_phone") @db.VarChar(15)
  studentEmail   String?           @map("student_email") @db.VarChar(255)
  dateOfBirth    DateTime?         @map("date_of_birth") @db.Date
  gender         Gender?
  address        String?           @db.VarChar(500)
  city           String?           @db.VarChar(100)
  state          String?           @db.VarChar(100)
  pincode        String?           @db.VarChar(10)
  previousSchool String?           @map("previous_school") @db.VarChar(200)
  bloodGroup     String?           @map("blood_group") @db.VarChar(5)
  classId        String?           @map("class_id") @db.Uuid
  batchId        String?           @map("batch_id") @db.Uuid
  guardians      Json              @default("[]")
  reviewedById   String?           @map("reviewed_by_id") @db.Uuid
  reviewedAt     DateTime?         @map("reviewed_at")
  rejectionNote  String?           @map("rejection_note") @db.VarChar(500)
  studentId      String?           @map("student_id") @db.Uuid
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")

  tenant     Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  inviteLink InviteLink? @relation(fields: [inviteLinkId], references: [id])
  reviewedBy User?       @relation("JoinRequestReviewer", fields: [reviewedById], references: [id])

  @@index([tenantId])
  @@index([tenantId, status])
  @@map("join_requests")
}

// ════════════════════════════════════════════════════════
// ATTENDANCE
// ════════════════════════════════════════════════════════

model AttendanceSession {
  id            String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String          @map("tenant_id") @db.Uuid
  batchId       String          @map("batch_id") @db.Uuid
  subjectId     String?         @map("subject_id") @db.Uuid
  type          AttendanceType
  date          DateTime        @db.Date
  startTime     String?         @map("start_time") @db.VarChar(5)
  endTime       String?         @map("end_time") @db.VarChar(5)
  markedById    String          @map("marked_by_id") @db.Uuid
  qrCode        String?         @unique @map("qr_code") @db.VarChar(64)
  qrExpiresAt   DateTime?       @map("qr_expires_at")
  examId        String?         @map("exam_id") @db.Uuid
  retestId      String?         @map("retest_id") @db.Uuid
  isFinalized   Boolean         @default(false) @map("is_finalized")
  totalPresent  Int             @default(0) @map("total_present")
  totalAbsent   Int             @default(0) @map("total_absent")
  totalLate     Int             @default(0) @map("total_late")
  note          String?         @db.VarChar(500)
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")

  tenant        Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  batch         Batch              @relation(fields: [batchId], references: [id])
  subject       Subject?           @relation(fields: [subjectId], references: [id])
  markedBy      User               @relation("AttendanceMarker", fields: [markedById], references: [id])
  records       AttendanceRecord[]
  exam          Exam?              @relation(fields: [examId], references: [id])

  @@unique([tenantId, batchId, type, date, startTime])
  @@index([tenantId])
  @@index([tenantId, batchId, date])
  @@index([tenantId, date])
  @@index([qrCode])
  @@map("attendance_sessions")
}

model AttendanceRecord {
  id                String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId          String           @map("tenant_id") @db.Uuid
  sessionId         String           @map("session_id") @db.Uuid
  studentId         String           @map("student_id") @db.Uuid
  status            AttendanceStatus @default(ABSENT)
  method            AttendanceMethod @default(MANUAL)

  homeBatchId       String           @map("home_batch_id") @db.Uuid
  attendedBatchId   String           @map("attended_batch_id") @db.Uuid
  isGuestInBatch    Boolean          @default(false) @map("is_guest_in_batch")

  markedAt          DateTime         @default(now()) @map("marked_at")
  markedById        String?          @map("marked_by_id") @db.Uuid
  deviceInfo        String?          @map("device_info") @db.VarChar(500)
  ipAddress         String?          @map("ip_address") @db.VarChar(45)
  note              String?          @db.VarChar(300)
  lateMinutes       Int?             @map("late_minutes")

  createdAt         DateTime         @default(now()) @map("created_at")
