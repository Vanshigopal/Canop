  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  tenant      Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  planItems   FeePlanItem[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("fee_categories")
}

model FeePlan {
  id                   String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId             String               @map("tenant_id") @db.Uuid
  batchId              String               @map("batch_id") @db.Uuid
  name                 String               @db.VarChar(200)
  academicYear         String               @map("academic_year") @db.VarChar(9)
  totalAmount          Decimal              @map("total_amount") @db.Decimal(10, 2)
  installmentCount     Int                  @default(1) @map("installment_count")
  installmentFrequency InstallmentFrequency @default(MONTHLY) @map("installment_frequency")
  dueDay               Int                  @default(1) @map("due_day")
  lateFeeAmount        Decimal?             @map("late_fee_amount") @db.Decimal(10, 2)
  lateFeePercent       Decimal?             @map("late_fee_percent") @db.Decimal(5, 2)
  gracePeriodDays      Int                  @default(7) @map("grace_period_days")
  gstPercent           Decimal?             @map("gst_percent") @db.Decimal(5, 2)
  isActive             Boolean              @default(true) @map("is_active")
  createdAt            DateTime             @default(now()) @map("created_at")
  updatedAt            DateTime             @updatedAt @map("updated_at")
  deletedAt            DateTime?            @map("deleted_at")

  tenant      Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  batch       Batch         @relation(fields: [batchId], references: [id])
  items       FeePlanItem[]
  studentFees StudentFee[]

  @@unique([tenantId, batchId, academicYear])
  @@index([tenantId])
  @@map("fee_plans")
}

model FeePlanItem {
  id         String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  planId     String  @map("plan_id") @db.Uuid
  categoryId String  @map("category_id") @db.Uuid
  amount     Decimal @db.Decimal(10, 2)

  plan     FeePlan     @relation(fields: [planId], references: [id], onDelete: Cascade)
  category FeeCategory @relation(fields: [categoryId], references: [id])

  @@unique([planId, categoryId])
  @@map("fee_plan_items")
}

model StudentFee {
  id             String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String        @map("tenant_id") @db.Uuid
  studentId      String        @map("student_id") @db.Uuid
  planId         String        @map("plan_id") @db.Uuid
  totalAmount    Decimal       @map("total_amount") @db.Decimal(10, 2)
  discountAmount Decimal       @default(0) @map("discount_amount") @db.Decimal(10, 2)
  discountReason String?       @map("discount_reason") @db.VarChar(300)
  discountType   DiscountType? @map("discount_type")
  paidAmount     Decimal       @default(0) @map("paid_amount") @db.Decimal(10, 2)
  pendingAmount  Decimal       @map("pending_amount") @db.Decimal(10, 2)
  status         FeeStatus     @default(PENDING)
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  student      Student       @relation(fields: [studentId], references: [id])
  plan         FeePlan       @relation(fields: [planId], references: [id])
  installments Installment[]
  payments     Payment[]

  @@unique([tenantId, studentId, planId])
  @@index([tenantId])
  @@index([tenantId, studentId])
  @@index([tenantId, status])
  @@map("student_fees")
}

model Installment {
  id                String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId          String            @map("tenant_id") @db.Uuid
  studentFeeId      String            @map("student_fee_id") @db.Uuid
  installmentNumber Int               @map("installment_number")
  amount            Decimal           @db.Decimal(10, 2)
  dueDate           DateTime          @map("due_date") @db.Date
  paidAmount        Decimal           @default(0) @map("paid_amount") @db.Decimal(10, 2)
  lateFee           Decimal           @default(0) @map("late_fee") @db.Decimal(10, 2)
  status            InstallmentStatus @default(UPCOMING)
  paidAt            DateTime?         @map("paid_at")
  reminderSentAt    DateTime?         @map("reminder_sent_at")
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")

  studentFee StudentFee @relation(fields: [studentFeeId], references: [id], onDelete: Cascade)
  payments   Payment[]

  @@unique([studentFeeId, installmentNumber])
  @@index([tenantId])
  @@index([tenantId, dueDate])
  @@index([tenantId, status])
  @@map("installments")
}

model Payment {
  id                 String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId           String        @map("tenant_id") @db.Uuid
  studentFeeId       String        @map("student_fee_id") @db.Uuid
  installmentId      String?       @map("installment_id") @db.Uuid
  amount             Decimal       @db.Decimal(10, 2)
  method             PaymentMethod
  status             PaymentStatus @default(PENDING)
  razorpayOrderId    String?       @unique @map("razorpay_order_id") @db.VarChar(100)
  razorpayPaymentId  String?       @unique @map("razorpay_payment_id") @db.VarChar(100)
  razorpaySignature  String?       @map("razorpay_signature") @db.VarChar(200)
  receiptNumber      String?       @map("receipt_number") @db.VarChar(50)
  transactionRef     String?       @map("transaction_ref") @db.VarChar(100)
  collectedById      String?       @map("collected_by_id") @db.Uuid
  note               String?       @db.VarChar(500)
  paidAt             DateTime?     @map("paid_at")
  createdAt          DateTime      @default(now()) @map("created_at")
  updatedAt          DateTime      @updatedAt @map("updated_at")

  studentFee  StudentFee   @relation(fields: [studentFeeId], references: [id])
  installment Installment? @relation(fields: [installmentId], references: [id])
  collectedBy User?        @relation("PaymentCollector", fields: [collectedById], references: [id])

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([razorpayOrderId])
  @@map("payments")
}

// ════════════════════════════════════════════════════════
// COMMUNICATIONS
// ════════════════════════════════════════════════════════

enum NotificationChannel {
  SMS
  WHATSAPP
  EMAIL
  IN_APP
}

enum AudienceType {
  ALL_STUDENTS
  ALL_PARENTS
  ALL_MEMBERS
  BATCH
  CLASS
  CUSTOM
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  SENDING
  SENT
  FAILED
  CANCELLED
}

enum DeliveryStatus {
  QUEUED
  SENDING
  SENT
  DELIVERED
  READ
  FAILED
  REJECTED
}

model NotificationTemplate {
  id        String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String              @map("tenant_id") @db.Uuid
  name      String              @db.VarChar(100)
  slug      String              @db.VarChar(100)
  eventType String              @map("event_type") @db.VarChar(50)
  channel   NotificationChannel
  subject   String?             @db.VarChar(300)
  body      String              @db.Text
  isDefault Boolean             @default(false) @map("is_default")
  isActive  Boolean             @default(true) @map("is_active")
  createdAt DateTime            @default(now()) @map("created_at")
  updatedAt DateTime            @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, slug, channel])
  @@index([tenantId])
  @@index([tenantId, eventType])
  @@map("notification_templates")
}

model BroadcastCampaign {
  id             String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String                @map("tenant_id") @db.Uuid
  title          String                @db.VarChar(200)
  message        String                @db.Text
  channels       NotificationChannel[]
  audienceType   AudienceType          @map("audience_type")
  audienceFilter Json?                 @map("audience_filter")
  recipientCount Int                   @default(0) @map("recipient_count")
  sentCount      Int                   @default(0) @map("sent_count")
  deliveredCount Int                   @default(0) @map("delivered_count")
  failedCount    Int                   @default(0) @map("failed_count")
  status         CampaignStatus        @default(DRAFT)
  scheduledAt    DateTime?             @map("scheduled_at")
  sentAt         DateTime?             @map("sent_at")
  createdById    String                @map("created_by_id") @db.Uuid
  createdAt      DateTime              @default(now()) @map("created_at")
  updatedAt      DateTime              @updatedAt @map("updated_at")

  tenant     Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy  User              @relation("BroadcastCreator", fields: [createdById], references: [id])
  deliveries MessageDelivery[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@map("broadcast_campaigns")
}

model MessageDelivery {
  id             String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String              @map("tenant_id") @db.Uuid
  campaignId     String?             @map("campaign_id") @db.Uuid
  recipientId    String              @map("recipient_id") @db.Uuid
  recipientPhone String?             @map("recipient_phone") @db.VarChar(15)
  recipientEmail String?             @map("recipient_email") @db.VarChar(255)
  channel        NotificationChannel
  eventType      String?             @map("event_type") @db.VarChar(50)
  message        String              @db.Text
  status         DeliveryStatus      @default(QUEUED)
  providerRef    String?             @map("provider_ref") @db.VarChar(200)
  errorMessage   String?             @map("error_message") @db.VarChar(500)
  sentAt         DateTime?           @map("sent_at")
  deliveredAt    DateTime?           @map("delivered_at")
  readAt         DateTime?           @map("read_at")
  createdAt      DateTime            @default(now()) @map("created_at")

  campaign BroadcastCampaign? @relation(fields: [campaignId], references: [id])

  @@index([tenantId])
  @@index([tenantId, recipientId])
  @@index([tenantId, eventType])
  @@index([campaignId])
  @@index([status])
  @@map("message_deliveries")
}

model NotificationPreference {
  id        String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String              @map("tenant_id") @db.Uuid
  userId    String              @map("user_id") @db.Uuid
  channel   NotificationChannel
  eventType String              @map("event_type") @db.VarChar(50)
  isEnabled Boolean             @default(true) @map("is_enabled")
  createdAt DateTime            @default(now()) @map("created_at")
  updatedAt DateTime            @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, channel, eventType])
  @@index([tenantId])
  @@index([userId])
  @@map("notification_preferences")
}

model ConsentRecord {
  id          String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String              @map("tenant_id") @db.Uuid
  userId      String              @map("user_id") @db.Uuid
  channel     NotificationChannel
  consented   Boolean             @default(true)
  consentedAt DateTime            @default(now()) @map("consented_at")
  revokedAt   DateTime?           @map("revoked_at")
  ipAddress   String?             @map("ip_address") @db.VarChar(45)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([userId, channel])
  @@map("consent_records")
}

// ════════════════════════════════════════════════════════
// EXAMS
// ════════════════════════════════════════════════════════

model Exam {
  id                  String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId            String     @map("tenant_id") @db.Uuid
  batchId             String     @map("batch_id") @db.Uuid
  subjectId           String?    @map("subject_id") @db.Uuid

  name                String     @db.VarChar(200)
  type                ExamType
  status              ExamStatus @default(DRAFT)
  description         String?    @db.VarChar(500)

  totalMarks          Decimal    @map("total_marks") @db.Decimal(8, 2)
  passingMarks        Decimal?   @map("passing_marks") @db.Decimal(8, 2)
  passingPercent      Decimal?   @map("passing_percent") @db.Decimal(5, 2)
  cutOffType          CutOffType @default(PERCENTAGE) @map("cut_off_type")

  totalQuestions      Int?       @map("total_questions")
  marksPerCorrect     Decimal?   @map("marks_per_correct") @db.Decimal(5, 2)
  marksPerWrong       Decimal?   @map("marks_per_wrong") @db.Decimal(5, 2)
  marksPerUnattempted Decimal?   @map("marks_per_unattempted") @db.Decimal(5, 2)

  theoryMaxMarks      Decimal?   @map("theory_max_marks") @db.Decimal(8, 2)
  mcqMaxMarks         Decimal?   @map("mcq_max_marks") @db.Decimal(8, 2)
  mcqQuestionCount    Int?       @map("mcq_question_count")

  examDate            DateTime?  @map("exam_date") @db.Date
  startTime           String?    @map("start_time") @db.VarChar(5)
  endTime             String?    @map("end_time") @db.VarChar(5)
  duration            Int?

  createdById         String     @map("created_by_id") @db.Uuid
  publishedAt         DateTime?  @map("published_at")
  publishedById       String?    @map("published_by_id") @db.Uuid
  createdAt           DateTime   @default(now()) @map("created_at")
  updatedAt           DateTime   @updatedAt @map("updated_at")
  deletedAt           DateTime?  @map("deleted_at")

  tenant              Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  batch               Batch               @relation(fields: [batchId], references: [id])
  subject             Subject?            @relation(fields: [subjectId], references: [id])
  createdBy           User                @relation("ExamCreator", fields: [createdById], references: [id])
  publishedBy         User?               @relation("ExamPublisher", fields: [publishedById], references: [id])
  markEntries         MarkEntry[]
  attendanceSessions  AttendanceSession[]
  retests             Retest[]
  omrScanResults      OmrScanResult[]

  @@index([tenantId])
  @@index([tenantId, batchId])
  @@index([tenantId, status])
  @@index([tenantId, examDate])
  @@map("exams")
}

model MarkEntry {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId          String    @map("tenant_id") @db.Uuid
  examId            String    @map("exam_id") @db.Uuid
  studentId         String    @map("student_id") @db.Uuid

  marksObtained     Decimal?  @map("marks_obtained") @db.Decimal(8, 2)
  percentage        Decimal?  @db.Decimal(5, 2)
  grade             String?   @db.VarChar(5)
  batchRank         Int?      @map("batch_rank")
  isPassed          Boolean?  @map("is_passed")
  isAbsent          Boolean   @default(false) @map("is_absent")

  theoryMarks       Decimal?  @map("theory_marks") @db.Decimal(8, 2)

  mcqCorrect        Int?      @map("mcq_correct")
  mcqIncorrect      Int?      @map("mcq_incorrect")
  mcqUnattempted    Int?      @map("mcq_unattempted")
  mcqPositiveMarks  Decimal?  @map("mcq_positive_marks") @db.Decimal(8, 2)
  mcqNegativeMarks  Decimal?  @map("mcq_negative_marks") @db.Decimal(8, 2)
  mcqNetMarks       Decimal?  @map("mcq_net_marks") @db.Decimal(8, 2)

  trendDirection    String?   @map("trend_direction") @db.VarChar(10)

  enteredById       String?   @map("entered_by_id") @db.Uuid
  enteredAt         DateTime? @map("entered_at")
  modifiedById      String?   @map("modified_by_id") @db.Uuid
  modifiedAt        DateTime? @map("modified_at")
  note              String?   @db.VarChar(300)

  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  exam              Exam      @relation(fields: [examId], references: [id], onDelete: Cascade)
  student           Student   @relation(fields: [studentId], references: [id])
  enteredBy         User?     @relation("MarkEnterer", fields: [enteredById], references: [id])

  @@unique([examId, studentId])
  @@index([tenantId])
  @@index([tenantId, studentId])
  @@index([examId])
  @@map("mark_entries")
}

// ════════════════════════════════════════════════════════
// RETEST
// ════════════════════════════════════════════════════════

model Retest {
  id                    String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId              String        @map("tenant_id") @db.Uuid
  examId                String        @map("exam_id") @db.Uuid
  studentId             String        @map("student_id") @db.Uuid

  originalMarks         Decimal       @map("original_marks") @db.Decimal(8, 2)
  originalPercentage    Decimal       @map("original_percentage") @db.Decimal(5, 2)
  cutOff                Decimal       @map("cut_off") @db.Decimal(8, 2)
  cutOffType            CutOffType    @map("cut_off_type")

  scheduledDate         DateTime?     @map("scheduled_date") @db.Date
  scheduledTime         String?       @map("scheduled_time") @db.VarChar(5)
  confirmedById         String?       @map("confirmed_by_id") @db.Uuid
  confirmedAt           DateTime?     @map("confirmed_at")

  retestMarks           Decimal?      @map("retest_marks") @db.Decimal(8, 2)
  retestPercentage      Decimal?      @map("retest_percentage") @db.Decimal(5, 2)
  retestIsPassed        Boolean?      @map("retest_is_passed")

  retestMcqCorrect      Int?          @map("retest_mcq_correct")
  retestMcqIncorrect    Int?          @map("retest_mcq_incorrect")
  retestMcqUnattempted  Int?          @map("retest_mcq_unattempted")
  retestTheoryMarks     Decimal?      @map("retest_theory_marks") @db.Decimal(8, 2)

  attendedAt            DateTime?     @map("attended_at")
  status                RetestStatus  @default(PENDING_SCHEDULE)
  noShowNotifiedAt      DateTime?     @map("no_show_notified_at")
  attendanceRecordId    String?       @map("attendance_record_id") @db.Uuid

  enteredById           String?       @map("entered_by_id") @db.Uuid
  note                  String?       @db.VarChar(500)
  createdAt             DateTime      @default(now()) @map("created_at")
  updatedAt             DateTime      @updatedAt @map("updated_at")

  exam                  Exam          @relation(fields: [examId], references: [id])
  student               Student       @relation(fields: [studentId], references: [id])
  confirmedBy           User?         @relation("RetestConfirmer", fields: [confirmedById], references: [id])
  enteredBy             User?         @relation("RetestMarksEnterer", fields: [enteredById], references: [id])

  @@unique([examId, studentId])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, scheduledDate])
  @@map("retests")
}

