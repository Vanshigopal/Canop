generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ════════════════════════════════════════════════════════
// ENUMS
// ════════════════════════════════════════════════════════

enum UserRole {
  ADMIN
  TEACHER
  STAFF
  PARENT
  STUDENT
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
  TRIAL
}

enum TenantTier {
  BASIC
  PROFESSIONAL
  ENTERPRISE
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum GuardianRelation {
  FATHER
  MOTHER
  GUARDIAN
  OTHER
}

enum JoinRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AttendanceType {
  LECTURE
  EXAM
  RETEST
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
}

enum AttendanceMethod {
  QR_SCAN
  MANUAL
  BULK
}

enum InstallmentFrequency {
  MONTHLY
  QUARTERLY
  HALF_YEARLY
  ANNUALLY
  CUSTOM
}

enum FeeStatus {
  PENDING
  PARTIALLY_PAID
  PAID
  OVERDUE
  WAIVED
}

enum DiscountType {
  PERCENTAGE
  FLAT
  SCHOLARSHIP
  SIBLING
  MERIT
  CUSTOM
}

enum InstallmentStatus {
  UPCOMING
  DUE
  OVERDUE
  PAID
  PARTIALLY_PAID
}

enum PaymentMethod {
  CASH
  UPI
  CARD
  NETBANKING
  CHEQUE
  RAZORPAY_ONLINE
  BANK_TRANSFER
  OTHER
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

// ════════════════════════════════════════════════════════
// CORE PLATFORM — not tenant-scoped (global tables)
// ════════════════════════════════════════════════════════

model Tenant {
  id           String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug         String       @unique @db.VarChar(30)
  name         String       @db.VarChar(200)
  status       TenantStatus @default(TRIAL)
  tier         TenantTier   @default(BASIC)
  logoUrl      String?      @map("logo_url")
  primaryColor String?      @map("primary_color") @db.VarChar(7)
  tagline      String?      @db.VarChar(300)
  timezone     String       @default("Asia/Kolkata") @db.VarChar(50)
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")
  deletedAt    DateTime?    @map("deleted_at")

  users                 User[]
  auditLogs             AuditLog[]
  subjects              Subject[]
  classes               ClassStandard[]
  batches               Batch[]
  students              Student[]
  inviteLinks           InviteLink[]
  joinRequests          JoinRequest[]
  attendanceSessions    AttendanceSession[]
  feeCategories         FeeCategory[]
  feePlans              FeePlan[]
  studentFees           StudentFee[]
  notificationTemplates NotificationTemplate[]
  broadcastCampaigns    BroadcastCampaign[]

  @@map("tenants")
}

// ════════════════════════════════════════════════════════
// TENANT-SCOPED TABLES — all have tenant_id + RLS
// ════════════════════════════════════════════════════════

model User {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String    @map("tenant_id") @db.Uuid
  email        String    @db.VarChar(255)
  passwordHash String?   @map("password_hash")
  name         String    @db.VarChar(200)
  role         UserRole  @default(ADMIN)
  phone        String?   @db.VarChar(15)
  avatarUrl    String?   @map("avatar_url")
  isActive     Boolean   @default(true) @map("is_active")
  lastLoginAt  DateTime? @map("last_login_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  tenant                   Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sessions                 Session[]
  auditLogs                AuditLog[]
  permissions              Permission?
  student                  Student?
  guardianOf               Guardian[]
  teacherSubjects          TeacherSubject[] @relation("TeacherSubjects")
  batchSubjects            BatchSubject[]   @relation("TeacherBatchSubjects")
  createdInvites           InviteLink[]     @relation("InviteCreator")
  reviewedJoinRequests     JoinRequest[]    @relation("JoinRequestReviewer")
  markedAttendanceSessions AttendanceSession[] @relation("AttendanceMarker")
  markedAttendanceRecords  AttendanceRecord[]  @relation("AttendanceRecordMarker")
  collectedPayments        Payment[]           @relation("PaymentCollector")
  broadcastCampaigns       BroadcastCampaign[]     @relation("BroadcastCreator")
  notificationPreferences  NotificationPreference[]
  consentRecords           ConsentRecord[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([tenantId, role])
  @@index([tenantId, phone])
  @@map("users")
}

model Session {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  refreshToken String   @unique @map("refresh_token")
  userAgent    String?  @map("user_agent") @db.VarChar(500)
  ipAddress    String?  @map("ip_address") @db.VarChar(45)
  expiresAt    DateTime @map("expires_at")
  createdAt    DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([userId])
  @@index([refreshToken])
  @@map("sessions")
}

model AuditLog {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  userId    String?  @map("user_id") @db.Uuid
  action    String   @db.VarChar(100)
  entity    String   @db.VarChar(100)
  entityId  String?  @map("entity_id") @db.Uuid
  before    Json?
  after     Json?
  ipAddress String?  @map("ip_address") @db.VarChar(45)
  createdAt DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([tenantId, entity])
  @@index([tenantId, userId])
  @@index([createdAt])
  @@map("audit_logs")
}

model Permission {
  id                   String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId             String   @map("tenant_id") @db.Uuid
  userId               String   @unique @map("user_id") @db.Uuid
  canManageFees        Boolean  @default(false) @map("can_manage_fees")
  canApproveAdmissions Boolean  @default(false) @map("can_approve_admissions")
  canManageExams       Boolean  @default(false) @map("can_manage_exams")
  canManageAttendance  Boolean  @default(false) @map("can_manage_attendance")
  canManageTimetable   Boolean  @default(false) @map("can_manage_timetable")
  canSendBroadcasts    Boolean  @default(false) @map("can_send_broadcasts")
  canViewAnalytics     Boolean  @default(false) @map("can_view_analytics")
  canManageContent     Boolean  @default(false) @map("can_manage_content")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@index([tenantId])
  @@map("permissions")
}

// ════════════════════════════════════════════════════════
// ACADEMIC STRUCTURE
// ════════════════════════════════════════════════════════

model Subject {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String    @map("tenant_id") @db.Uuid
  name        String    @db.VarChar(100)
  code        String?   @db.VarChar(20)
  description String?   @db.VarChar(500)
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  tenant             Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  batchSubjects      BatchSubject[]
  teacherSubjects    TeacherSubject[]
  attendanceSessions AttendanceSession[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("subjects")
}

model ClassStandard {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId   String    @map("tenant_id") @db.Uuid
  name       String    @db.VarChar(50)
  orderIndex Int       @default(0) @map("order_index")
  isActive   Boolean   @default(true) @map("is_active")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  deletedAt  DateTime? @map("deleted_at")

  tenant      Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  batches     Batch[]
  students    Student[]
  inviteLinks InviteLink[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("class_standards")
}

model Batch {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String    @map("tenant_id") @db.Uuid
  classId      String    @map("class_id") @db.Uuid
  name         String    @db.VarChar(100)
  capacity     Int       @default(60)
  academicYear String    @map("academic_year") @db.VarChar(9)
  startDate    DateTime? @map("start_date")
  endDate      DateTime? @map("end_date")
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  tenant             Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  class              ClassStandard  @relation(fields: [classId], references: [id])
  batchSubjects      BatchSubject[]
  students           Student[]
  inviteLinks        InviteLink[]
  attendanceSessions AttendanceSession[]
  studentBatches     StudentBatch[]
  feePlans           FeePlan[]

  @@unique([tenantId, name, academicYear])
  @@index([tenantId])
  @@index([tenantId, classId])
  @@map("batches")
}

model BatchSubject {
  id        String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String  @map("tenant_id") @db.Uuid
  batchId   String  @map("batch_id") @db.Uuid
  subjectId String  @map("subject_id") @db.Uuid
  teacherId String? @map("teacher_id") @db.Uuid

  batch   Batch   @relation(fields: [batchId], references: [id], onDelete: Cascade)
  subject Subject @relation(fields: [subjectId], references: [id])
  teacher User?   @relation("TeacherBatchSubjects", fields: [teacherId], references: [id])

  @@unique([batchId, subjectId])
  @@index([tenantId])
  @@map("batch_subjects")
}

// ════════════════════════════════════════════════════════
// TEACHER PROFILE (extends User with role TEACHER)
// ════════════════════════════════════════════════════════

model TeacherSubject {
  id        String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String @map("tenant_id") @db.Uuid
  teacherId String @map("teacher_id") @db.Uuid
  subjectId String @map("subject_id") @db.Uuid

  teacher User    @relation("TeacherSubjects", fields: [teacherId], references: [id], onDelete: Cascade)
  subject Subject @relation(fields: [subjectId], references: [id])

  @@unique([teacherId, subjectId])
  @@index([tenantId])
  @@map("teacher_subjects")
}

// ════════════════════════════════════════════════════════
// STUDENT & GUARDIAN (created via enrollment flow)
// ════════════════════════════════════════════════════════

model Student {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String    @map("tenant_id") @db.Uuid
  userId         String    @unique @map("user_id") @db.Uuid
  batchId        String?   @map("batch_id") @db.Uuid
  classId        String?   @map("class_id") @db.Uuid
  rollNumber     String?   @map("roll_number") @db.VarChar(30)
  dateOfBirth    DateTime? @map("date_of_birth") @db.Date
  gender         Gender?
  address        String?   @db.VarChar(500)
  city           String?   @db.VarChar(100)
  state          String?   @db.VarChar(100)
  pincode        String?   @db.VarChar(10)
  previousSchool String?   @map("previous_school") @db.VarChar(200)
  bloodGroup     String?   @map("blood_group") @db.VarChar(5)
  photoUrl       String?   @map("photo_url")
  enrolledAt     DateTime  @default(now()) @map("enrolled_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  tenant             Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user               User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  batch              Batch?         @relation(fields: [batchId], references: [id])
  class              ClassStandard? @relation(fields: [classId], references: [id])
  guardians          Guardian[]
  attendanceRecords  AttendanceRecord[]
  batches            StudentBatch[]
  fees               StudentFee[]

  @@index([tenantId])
  @@index([tenantId, batchId])
  @@map("students")
}

model Guardian {
  id          String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String           @map("tenant_id") @db.Uuid
  studentId   String           @map("student_id") @db.Uuid
  userId      String?          @map("user_id") @db.Uuid
  name        String           @db.VarChar(200)
  relation    GuardianRelation
  phone       String           @db.VarChar(15)
  email       String?          @db.VarChar(255)
  occupation  String?          @db.VarChar(100)
  isEmergency Boolean          @default(false) @map("is_emergency")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id])

  @@index([tenantId])
  @@index([studentId])
  @@map("guardians")
}

// ════════════════════════════════════════════════════════
// ENROLLMENT FLOW (invite → form → approval)
// ════════════════════════════════════════════════════════

model InviteLink {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String    @map("tenant_id") @db.Uuid
  code        String    @unique @db.VarChar(12)
  batchId     String?   @map("batch_id") @db.Uuid
  classId     String?   @map("class_id") @db.Uuid
  createdById String    @map("created_by_id") @db.Uuid
  maxUses     Int       @default(0) @map("max_uses")
  usedCount   Int       @default(0) @map("used_count")
  expiresAt   DateTime? @map("expires_at")
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")

  tenant       Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  batch        Batch?         @relation(fields: [batchId], references: [id])
  class        ClassStandard? @relation(fields: [classId], references: [id])
  createdBy    User           @relation("InviteCreator", fields: [createdById], references: [id])
  joinRequests JoinRequest[]

  @@index([tenantId])
  @@index([code])
  @@map("invite_links")
}

model JoinRequest {
  id             String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String            @map("tenant_id") @db.Uuid
  inviteLinkId   String?           @map("invite_link_id") @db.Uuid
  status         JoinRequestStatus @default(PENDING)
  studentName    String            @map("student_name") @db.VarChar(200)
  studentPhone   String            @map("student_phone") @db.VarChar(15)
  studentEmail   String?           @map("student_email") @db.VarChar(255)
  dateOfBirth    DateTime?         @map("date_of_birth") @db.Date
  gender         Gender?
  address        String?           @db.VarChar(500)
  city           String?           @db.VarChar(100)
  state          String?           @db.VarChar(100)
  pincode        String?           @db.VarChar(10)
  previousSchool String?           @map("previous_school") @db.VarChar(200)
  bloodGroup     String?           @map("blood_group") @db.VarChar(5)
  classId        String?           @map("class_id") @db.Uuid
  batchId        String?           @map("batch_id") @db.Uuid
  guardians      Json              @default("[]")
  reviewedById   String?           @map("reviewed_by_id") @db.Uuid
  reviewedAt     DateTime?         @map("reviewed_at")
  rejectionNote  String?           @map("rejection_note") @db.VarChar(500)
  studentId      String?           @map("student_id") @db.Uuid
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")

  tenant     Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  inviteLink InviteLink? @relation(fields: [inviteLinkId], references: [id])
  reviewedBy User?       @relation("JoinRequestReviewer", fields: [reviewedById], references: [id])

  @@index([tenantId])
  @@index([tenantId, status])
  @@map("join_requests")
}

// ════════════════════════════════════════════════════════
// ATTENDANCE
// ════════════════════════════════════════════════════════

model AttendanceSession {
  id            String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String          @map("tenant_id") @db.Uuid
  batchId       String          @map("batch_id") @db.Uuid
  subjectId     String?         @map("subject_id") @db.Uuid
  type          AttendanceType
  date          DateTime        @db.Date
  startTime     String?         @map("start_time") @db.VarChar(5)
  endTime       String?         @map("end_time") @db.VarChar(5)
  markedById    String          @map("marked_by_id") @db.Uuid
  qrCode        String?         @unique @map("qr_code") @db.VarChar(64)
  qrExpiresAt   DateTime?       @map("qr_expires_at")
  examId        String?         @map("exam_id") @db.Uuid
  retestId      String?         @map("retest_id") @db.Uuid
  isFinalized   Boolean         @default(false) @map("is_finalized")
  totalPresent  Int             @default(0) @map("total_present")
  totalAbsent   Int             @default(0) @map("total_absent")
  totalLate     Int             @default(0) @map("total_late")
  note          String?         @db.VarChar(500)
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")

  tenant        Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  batch         Batch              @relation(fields: [batchId], references: [id])
  subject       Subject?           @relation(fields: [subjectId], references: [id])
  markedBy      User               @relation("AttendanceMarker", fields: [markedById], references: [id])
  records       AttendanceRecord[]

  @@unique([tenantId, batchId, type, date, startTime])
  @@index([tenantId])
  @@index([tenantId, batchId, date])
  @@index([tenantId, date])
  @@index([qrCode])
  @@map("attendance_sessions")
}

model AttendanceRecord {
  id                String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId          String           @map("tenant_id") @db.Uuid
  sessionId         String           @map("session_id") @db.Uuid
  studentId         String           @map("student_id") @db.Uuid
  status            AttendanceStatus @default(ABSENT)
  method            AttendanceMethod @default(MANUAL)

  homeBatchId       String           @map("home_batch_id") @db.Uuid
  attendedBatchId   String           @map("attended_batch_id") @db.Uuid
  isGuestInBatch    Boolean          @default(false) @map("is_guest_in_batch")

  markedAt          DateTime         @default(now()) @map("marked_at")
  markedById        String?          @map("marked_by_id") @db.Uuid
  deviceInfo        String?          @map("device_info") @db.VarChar(500)
  ipAddress         String?          @map("ip_address") @db.VarChar(45)
  note              String?          @db.VarChar(300)
  lateMinutes       Int?             @map("late_minutes")

  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")

  session           AttendanceSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  student           Student           @relation(fields: [studentId], references: [id])
  markedBy          User?             @relation("AttendanceRecordMarker", fields: [markedById], references: [id])

  @@unique([sessionId, studentId])
  @@index([tenantId])
  @@index([tenantId, studentId])
  @@index([tenantId, studentId, status])
  @@index([sessionId])
  @@index([homeBatchId])
  @@map("attendance_records")
}

model StudentBatch {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId   String    @map("tenant_id") @db.Uuid
  studentId  String    @map("student_id") @db.Uuid
  batchId    String    @map("batch_id") @db.Uuid
  isPrimary  Boolean   @default(false) @map("is_primary")
  joinedAt   DateTime  @default(now()) @map("joined_at")
  leftAt     DateTime? @map("left_at")

  student    Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  batch      Batch     @relation(fields: [batchId], references: [id])

  @@unique([studentId, batchId])
  @@index([tenantId])
  @@index([batchId])
  @@map("student_batches")
}

// ════════════════════════════════════════════════════════
// FEE MANAGEMENT
// ════════════════════════════════════════════════════════

model FeeCategory {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String    @map("tenant_id") @db.Uuid
  name        String    @db.VarChar(100)
  description String?   @db.VarChar(300)
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  tenant      Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  planItems   FeePlanItem[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("fee_categories")
}

model FeePlan {
  id                   String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId             String               @map("tenant_id") @db.Uuid
  batchId              String               @map("batch_id") @db.Uuid
  name                 String               @db.VarChar(200)
  academicYear         String               @map("academic_year") @db.VarChar(9)
  totalAmount          Decimal              @map("total_amount") @db.Decimal(10, 2)
  installmentCount     Int                  @default(1) @map("installment_count")
  installmentFrequency InstallmentFrequency @default(MONTHLY) @map("installment_frequency")
  dueDay               Int                  @default(1) @map("due_day")
  lateFeeAmount        Decimal?             @map("late_fee_amount") @db.Decimal(10, 2)
  lateFeePercent       Decimal?             @map("late_fee_percent") @db.Decimal(5, 2)
  gracePeriodDays      Int                  @default(7) @map("grace_period_days")
  gstPercent           Decimal?             @map("gst_percent") @db.Decimal(5, 2)
  isActive             Boolean              @default(true) @map("is_active")
  createdAt            DateTime             @default(now()) @map("created_at")
  updatedAt            DateTime             @updatedAt @map("updated_at")
  deletedAt            DateTime?            @map("deleted_at")

  tenant      Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  batch       Batch         @relation(fields: [batchId], references: [id])
  items       FeePlanItem[]
  studentFees StudentFee[]

  @@unique([tenantId, batchId, academicYear])
  @@index([tenantId])
  @@map("fee_plans")
}

model FeePlanItem {
  id         String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  planId     String  @map("plan_id") @db.Uuid
  categoryId String  @map("category_id") @db.Uuid
  amount     Decimal @db.Decimal(10, 2)

  plan     FeePlan     @relation(fields: [planId], references: [id], onDelete: Cascade)
  category FeeCategory @relation(fields: [categoryId], references: [id])

  @@unique([planId, categoryId])
  @@map("fee_plan_items")
}

model StudentFee {
  id             String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String        @map("tenant_id") @db.Uuid
  studentId      String        @map("student_id") @db.Uuid
  planId         String        @map("plan_id") @db.Uuid
  totalAmount    Decimal       @map("total_amount") @db.Decimal(10, 2)
  discountAmount Decimal       @default(0) @map("discount_amount") @db.Decimal(10, 2)
  discountReason String?       @map("discount_reason") @db.VarChar(300)
  discountType   DiscountType? @map("discount_type")
  paidAmount     Decimal       @default(0) @map("paid_amount") @db.Decimal(10, 2)
  pendingAmount  Decimal       @map("pending_amount") @db.Decimal(10, 2)
  status         FeeStatus     @default(PENDING)
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  student      Student       @relation(fields: [studentId], references: [id])
  plan         FeePlan       @relation(fields: [planId], references: [id])
  installments Installment[]
  payments     Payment[]

  @@unique([tenantId, studentId, planId])
  @@index([tenantId])
  @@index([tenantId, studentId])
  @@index([tenantId, status])
  @@map("student_fees")
}

model Installment {
  id                String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId          String            @map("tenant_id") @db.Uuid
  studentFeeId      String            @map("student_fee_id") @db.Uuid
  installmentNumber Int               @map("installment_number")
  amount            Decimal           @db.Decimal(10, 2)
  dueDate           DateTime          @map("due_date") @db.Date
  paidAmount        Decimal           @default(0) @map("paid_amount") @db.Decimal(10, 2)
  lateFee           Decimal           @default(0) @map("late_fee") @db.Decimal(10, 2)
  status            InstallmentStatus @default(UPCOMING)
  paidAt            DateTime?         @map("paid_at")
  reminderSentAt    DateTime?         @map("reminder_sent_at")
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")

  studentFee StudentFee @relation(fields: [studentFeeId], references: [id], onDelete: Cascade)
  payments   Payment[]

  @@unique([studentFeeId, installmentNumber])
  @@index([tenantId])
  @@index([tenantId, dueDate])
  @@index([tenantId, status])
  @@map("installments")
}

model Payment {
  id                 String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId           String        @map("tenant_id") @db.Uuid
  studentFeeId       String        @map("student_fee_id") @db.Uuid
  installmentId      String?       @map("installment_id") @db.Uuid
  amount             Decimal       @db.Decimal(10, 2)
  method             PaymentMethod
  status             PaymentStatus @default(PENDING)
  razorpayOrderId    String?       @unique @map("razorpay_order_id") @db.VarChar(100)
  razorpayPaymentId  String?       @unique @map("razorpay_payment_id") @db.VarChar(100)
  razorpaySignature  String?       @map("razorpay_signature") @db.VarChar(200)
  receiptNumber      String?       @map("receipt_number") @db.VarChar(50)
  transactionRef     String?       @map("transaction_ref") @db.VarChar(100)
  collectedById      String?       @map("collected_by_id") @db.Uuid
  note               String?       @db.VarChar(500)
  paidAt             DateTime?     @map("paid_at")
  createdAt          DateTime      @default(now()) @map("created_at")
  updatedAt          DateTime      @updatedAt @map("updated_at")

  studentFee  StudentFee   @relation(fields: [studentFeeId], references: [id])
  installment Installment? @relation(fields: [installmentId], references: [id])
  collectedBy User?        @relation("PaymentCollector", fields: [collectedById], references: [id])

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([razorpayOrderId])
  @@map("payments")
}

// ════════════════════════════════════════════════════════
// COMMUNICATIONS
// ════════════════════════════════════════════════════════

enum NotificationChannel {
  SMS
  WHATSAPP
  EMAIL
  IN_APP
}

enum AudienceType {
  ALL_STUDENTS
  ALL_PARENTS
  ALL_MEMBERS
  BATCH
  CLASS
  CUSTOM
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  SENDING
  SENT
  FAILED
  CANCELLED
}

enum DeliveryStatus {
  QUEUED
  SENDING
  SENT
  DELIVERED
  READ
  FAILED
  REJECTED
}

model NotificationTemplate {
  id        String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String              @map("tenant_id") @db.Uuid
  name      String              @db.VarChar(100)
  slug      String              @db.VarChar(100)
  eventType String              @map("event_type") @db.VarChar(50)
  channel   NotificationChannel
  subject   String?             @db.VarChar(300)
  body      String              @db.Text
  isDefault Boolean             @default(false) @map("is_default")
  isActive  Boolean             @default(true) @map("is_active")
  createdAt DateTime            @default(now()) @map("created_at")
  updatedAt DateTime            @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, slug, channel])
  @@index([tenantId])
  @@index([tenantId, eventType])
  @@map("notification_templates")
}

model BroadcastCampaign {
  id             String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String                @map("tenant_id") @db.Uuid
  title          String                @db.VarChar(200)
  message        String                @db.Text
  channels       NotificationChannel[]
  audienceType   AudienceType          @map("audience_type")
  audienceFilter Json?                 @map("audience_filter")
  recipientCount Int                   @default(0) @map("recipient_count")
  sentCount      Int                   @default(0) @map("sent_count")
  deliveredCount Int                   @default(0) @map("delivered_count")
  failedCount    Int                   @default(0) @map("failed_count")
  status         CampaignStatus        @default(DRAFT)
  scheduledAt    DateTime?             @map("scheduled_at")
  sentAt         DateTime?             @map("sent_at")
  createdById    String                @map("created_by_id") @db.Uuid
  createdAt      DateTime              @default(now()) @map("created_at")
  updatedAt      DateTime              @updatedAt @map("updated_at")

  tenant     Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy  User              @relation("BroadcastCreator", fields: [createdById], references: [id])
  deliveries MessageDelivery[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@map("broadcast_campaigns")
}

model MessageDelivery {
  id             String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String              @map("tenant_id") @db.Uuid
  campaignId     String?             @map("campaign_id") @db.Uuid
  recipientId    String              @map("recipient_id") @db.Uuid
  recipientPhone String?             @map("recipient_phone") @db.VarChar(15)
  recipientEmail String?             @map("recipient_email") @db.VarChar(255)
  channel        NotificationChannel
  eventType      String?             @map("event_type") @db.VarChar(50)
  message        String              @db.Text
  status         DeliveryStatus      @default(QUEUED)
  providerRef    String?             @map("provider_ref") @db.VarChar(200)
  errorMessage   String?             @map("error_message") @db.VarChar(500)
  sentAt         DateTime?           @map("sent_at")
  deliveredAt    DateTime?           @map("delivered_at")
  readAt         DateTime?           @map("read_at")
  createdAt      DateTime            @default(now()) @map("created_at")

  campaign BroadcastCampaign? @relation(fields: [campaignId], references: [id])

  @@index([tenantId])
  @@index([tenantId, recipientId])
  @@index([tenantId, eventType])
  @@index([campaignId])
  @@index([status])
  @@map("message_deliveries")
}

model NotificationPreference {
  id        String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String              @map("tenant_id") @db.Uuid
  userId    String              @map("user_id") @db.Uuid
  channel   NotificationChannel
  eventType String              @map("event_type") @db.VarChar(50)
  isEnabled Boolean             @default(true) @map("is_enabled")
  createdAt DateTime            @default(now()) @map("created_at")
  updatedAt DateTime            @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, channel, eventType])
  @@index([tenantId])
  @@index([userId])
  @@map("notification_preferences")
}

model ConsentRecord {
  id          String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String              @map("tenant_id") @db.Uuid
  userId      String              @map("user_id") @db.Uuid
  channel     NotificationChannel
  consented   Boolean             @default(true)
  consentedAt DateTime            @default(now()) @map("consented_at")
  revokedAt   DateTime?           @map("revoked_at")
  ipAddress   String?             @map("ip_address") @db.VarChar(45)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([userId, channel])
  @@map("consent_records")
}
