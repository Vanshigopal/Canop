  marksScore         Decimal   @map("marks_score") @db.Decimal(5, 2)
  assignmentScore    Decimal   @map("assignment_score") @db.Decimal(5, 2)
  videoScore         Decimal   @map("video_score") @db.Decimal(5, 2)
  loginScore         Decimal   @map("login_score") @db.Decimal(5, 2)
  riskFactors        Json
