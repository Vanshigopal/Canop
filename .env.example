# Database
DATABASE_URL="postgresql://raquel:raquel_dev_password@localhost:5432/raquel_dev?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# API
PORT=3001
CORS_ORIGIN="http://localhost:5173"
NODE_ENV=development

# Auth
JWT_SECRET="raquel-dev-secret-change-in-production-please"
JWT_ACCESS_TTL="900"
JWT_REFRESH_TTL="604800"
OTP_TTL="300"

# Razorpay (leave placeholder values for stub/mock mode)
RAZORPAY_KEY_ID="rzp_test_placeholder"
RAZORPAY_KEY_SECRET="placeholder_secret"

# Gupshup (leave empty for local stub mode)
GUPSHUP_API_KEY=""
GUPSHUP_APP_NAME=""
GUPSHUP_SENDER_ID=""

# LLM / Claude (Session 11) — leave empty for stub mode
# ANTHROPIC_API_KEY is the platform-level key used when tenants pick "Platform Key" mode.
# LLM_ENCRYPTION_KEY is an optional dedicated secret for encrypting tenant-supplied keys
# at rest; falls back to JWT_SECRET if not set.
ANTHROPIC_API_KEY=""
LLM_ENCRYPTION_KEY=""

# Storage (Session 12) — leave empty for local filesystem (./uploads)
# Set these to use Cloudflare R2 in production
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="raquel-uploads"
R2_PUBLIC_URL=""

# Bunny Stream (Session 12) — leave empty for stub mode (no real video transcoding)
BUNNY_STREAM_API_KEY=""
BUNNY_STREAM_LIBRARY_ID=""
BUNNY_STREAM_CDN_HOSTNAME=""

# Frontend
VITE_API_URL="http://localhost:3001"
