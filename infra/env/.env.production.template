# ══════════════════════════════════════════════════════════
# RAQUEL — PRODUCTION ENVIRONMENT VARIABLES
# Copy to .env.production and fill ALL values.
# NEVER commit the filled file.
# ══════════════════════════════════════════════════════════

# ─── Core ───
NODE_ENV=production
PORT=3001

# ─── Database (managed Postgres: Railway, Supabase, Neon) ───
# MUST include sslmode=require for production (encrypts DB traffic)
DATABASE_URL="postgresql://raquel:STRONG_PASSWORD@db-host:5432/raquel_prod?schema=public&connection_limit=20&sslmode=require"

# Compose-only (if using docker-compose.prod.yml)
DB_USER=raquel
DB_PASSWORD=GENERATE_STRONG_PASSWORD_HERE
DB_NAME=raquel_prod

# ─── Redis ───
# Use rediss:// (TLS) for managed Redis in production
REDIS_URL="rediss://redis-host:6380"

# ─── Auth ───
# Generate: openssl rand -hex 64
JWT_SECRET="REPLACE_WITH_64_CHAR_HEX"
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=604800
OTP_TTL=300

# ─── CORS / Frontend ───
CORS_ORIGIN="https://raquel.app"
VITE_API_URL="https://api.raquel.app"
VITE_APP_VERSION="0.1.0"

# ─── Razorpay (LIVE keys after KYC) ───
RAZORPAY_KEY_ID="rzp_live_xxxxxxxxxxxxxx"
RAZORPAY_KEY_SECRET="xxxxxxxxxxxxxxxxx"

# ─── Gupshup (WhatsApp + SMS) ───
GUPSHUP_API_KEY="your-gupshup-api-key"
GUPSHUP_APP_NAME="raquel"
GUPSHUP_SENDER_ID="RAQUEL"

# ─── Anthropic Claude (optional) ───
ANTHROPIC_API_KEY="sk-ant-api03-xxxxxx"

# ─── LLM Encryption ───
# Generate: openssl rand -hex 32
LLM_ENCRYPTION_KEY="REPLACE_WITH_32_CHAR_HEX"

# ─── Bunny Stream (video) ───
BUNNY_STREAM_LIBRARY_ID="your-library-id"
BUNNY_STREAM_API_KEY="your-api-key"
BUNNY_STREAM_CDN_HOSTNAME="your-cdn.b-cdn.net"

# ─── Cloudflare R2 (file storage) ───
R2_ACCOUNT_ID="your-account-id"
R2_ACCESS_KEY_ID="your-access-key"
R2_SECRET_ACCESS_KEY="your-secret-key"
R2_BUCKET_NAME="raquel-uploads"
R2_PUBLIC_URL="https://uploads.raquel.app"

# ─── Email (Resend) ───
RESEND_API_KEY="re_xxxxxxxxxxxx"
RESEND_FROM_EMAIL="noreply@raquel.app"

# ─── ML Service ───
ML_SERVICE_URL="http://ml-service:8000"
# Generate: openssl rand -hex 24
ML_SERVICE_API_KEY="REPLACE_WITH_48_CHAR_HEX"

# ─── Monitoring ───
SENTRY_DSN="https://xxxx@sentry.io/xxxx"
VITE_SENTRY_DSN="https://xxxx@sentry.io/xxxx"

# ─── Production Seed (first-run only) ───
ADMIN_EMAIL="owner@institute.com"
ADMIN_PASSWORD="FirstLoginPassword123!"
TENANT_NAME="My Institute"
TENANT_SLUG="my-institute"

# Platform super admin (Vanshigopal)
PLATFORM_ADMIN_EMAIL="vansh@raquel.app"
PLATFORM_ADMIN_PASSWORD="REPLACE_WITH_STRONG_PASSWORD"
