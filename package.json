{
  "name": "raquel",
  "version": "0.1.0",
  "private": true,
  "description": "Raquel — AI-powered institutional ERP platform (monorepo root)",
  "scripts": {
    "dev": "turbo dev",
    "dev:web": "turbo dev --filter=@raquel/web",
    "dev:api": "turbo dev --filter=@raquel/api",
    "build": "turbo build",
    "typecheck": "turbo typecheck",
    "lint": "biome check .",
    "format": "biome format --write .",
    "clean": "turbo clean && rimraf node_modules",
    "db:up": "docker compose -f infra/docker/docker-compose.yml up -d",
    "db:down": "docker compose -f infra/docker/docker-compose.yml down",
    "db:reset": "docker compose -f infra/docker/docker-compose.yml down -v && pnpm db:up"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^20.17.6",
    "rimraf": "^6.0.1",
    "turbo": "^2.3.3",
    "typescript": "^5.6.3"
  },
  "packageManager": "pnpm@9.12.3",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  }
}
