{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "globalEnv": ["NODE_ENV"],
  "globalPassThroughEnv": ["CI"],
  "tasks": {
    "dev": { "cache": false, "persistent": true },
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "build/**", ".next/**"]
    },
    "typecheck": { "dependsOn": ["^typecheck"] },
    "lint": {},
    "clean": { "cache": false },
    "@canop/mobile#typecheck": {
      "dependsOn": ["^build"]
    },
    "@canop/mobile#android": {
      "cache": false,
      "persistent": true
    },
    "@canop/mobile#build:android": {
      "outputs": ["android/app/build/outputs/**"]
    },
    "@canop/desktop#typecheck": {
      "dependsOn": ["^build"]
    },
    "@canop/desktop#build": {
      "dependsOn": ["@canop/web#build"],
      "outputs": ["release/**", "dist/**"]
    }
  }
}
